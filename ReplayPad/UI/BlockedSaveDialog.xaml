<Window x:Class="ReplayPad.UI.BlockedSaveDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows blocked the save"
        Icon="/app.ico"
        Width="480" SizeToContent="Height" ResizeMode="NoResize"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen" Topmost="True">
    <StackPanel Margin="20,16,20,18">
        <TextBlock Text="Your recording was rescued 👍" Style="{StaticResource H2}"/>
        <TextBlock x:Name="ExplainText" Style="{StaticResource Dim}" FontSize="12"
                   TextWrapping="Wrap" Margin="0,8,0,0"
                   Text="Windows Ransomware Protection blocked ReplayPad from saving into your output folder, so the clip was saved to a safe fallback folder instead. Pick how you want to fix this permanently:"/>

        <Button Style="{StaticResource BtnAccent}" Margin="0,16,0,0" Padding="12,10"
                HorizontalContentAlignment="Left" Click="OnAllowClick">
            <StackPanel>
                <TextBlock Text="Allow ReplayPad in Windows Security   (recommended)" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Text="Opens the Ransomware Protection page — choose “Allow an app through Controlled folder access”, then pick ReplayPad from “Recently blocked apps”. Keeps your library where it is."
                           FontSize="11" Foreground="#DDFFFFFF" TextWrapping="Wrap" Margin="0,3,0,0"/>
            </StackPanel>
        </Button>

        <Button Style="{StaticResource Btn}" Margin="0,8,0,0" Padding="12,10"
                HorizontalContentAlignment="Left" Click="OnSwitchClick">
            <StackPanel>
                <TextBlock x:Name="SwitchTitle" Text="Switch my library to an unprotected folder" FontWeight="SemiBold"/>
                <TextBlock x:Name="SwitchSub" FontSize="11" Foreground="{StaticResource DimBrush}"
                           TextWrapping="Wrap" Margin="0,3,0,0"
                           Text="Saves will go to a folder Windows doesn't guard. Files already in the old folder stay there — move them in Explorer if you want them back in the app."/>
            </StackPanel>
        </Button>

        <Button Style="{StaticResource Btn}" Margin="0,8,0,0" Padding="12,8"
                Content="Not now" Click="OnDismissClick"/>
    </StackPanel>
</Window>
