<Window x:Class="ReplayPad.UI.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:ReplayPad.UI"
        Title="Rename replay"
        Icon="/app.ico"
        Width="420" SizeToContent="Height" ResizeMode="NoResize"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <StackPanel Margin="18,14,18,16">
        <TextBlock Text="Label (friendly name shown in the list)" Style="{StaticResource Lbl}"/>
        <TextBox x:Name="LabelBox"/>

        <TextBlock Text="File name" Style="{StaticResource Lbl}"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="NameBox" Grid.Column="0"/>
            <TextBlock x:Name="ExtText" Grid.Column="1" Style="{StaticResource Dim}"
                       VerticalAlignment="Center" Margin="8,0,0,0" Text=".mp3"/>
        </Grid>

        <Grid>
            <TextBlock Text="Sound volume" Style="{StaticResource Lbl}"/>
            <TextBlock x:Name="VolumeText" Style="{StaticResource Dim}" FontSize="12"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom" Text="100%"/>
        </Grid>
        <Slider x:Name="VolumeSlider" Minimum="10" Maximum="300" Value="100" TickFrequency="5"
                IsSnapToTickEnabled="True" ValueChanged="OnVolumeChanged"/>

        <TextBlock Text="Pad color" Style="{StaticResource Lbl}"/>
        <WrapPanel x:Name="ColorRow"/>

        <TextBlock x:Name="CategoryLabel" Text="Category" Style="{StaticResource Lbl}"/>
        <ComboBox x:Name="CategoryBox" SelectionChanged="OnCategoryChanged"/>

        <TextBlock Text="Soundboard hotkey (slot)" Style="{StaticResource Lbl}"/>
        <ComboBox x:Name="SlotBox"/>

        <TextBlock Text="Custom hotkey (optional)" Style="{StaticResource Lbl}"/>
        <ui:HotkeyBox x:Name="CustomHotkeyBox"/>
        <TextBlock Style="{StaticResource Dim}" FontSize="11" TextWrapping="Wrap" Margin="0,8,0,0"
                   Text="The hotkey plays this sound into your call from anywhere, even mid-game. Ctrl+Alt+0 stops playback. Picking a hotkey that is in use moves it to this sound."/>

        <TextBlock x:Name="ErrorText" FontSize="12" Foreground="{StaticResource WarnBrush}"
                   TextWrapping="Wrap" Margin="0,8,0,0" Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource Btn}" Content="Cancel" Padding="16,8" Click="OnCancelClick"/>
            <Button Style="{StaticResource BtnAccent}" Content="Save" Padding="22,8"
                    Margin="8,0,0,0" Click="OnSaveClick"/>
        </StackPanel>
    </StackPanel>
</Window>
