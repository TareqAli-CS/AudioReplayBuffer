<Window x:Class="AudioReplayBuffer.UI.TranscriptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transcript"
        Icon="/app.ico"
        Width="680" Height="600" MinWidth="500" MinHeight="400"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18,14,18,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock x:Name="FileNameText" Style="{StaticResource H2}" Text="Replay.mp3"/>
                <TextBlock x:Name="StatusText" Style="{StaticResource Dim}" FontSize="12"
                           Margin="0,3,0,0" Text="Transcribing — uploading to Groq…"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock x:Name="PositionText" Style="{StaticResource Dim}" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,10,0" Text=""/>
                <Button x:Name="PlayBtn" Style="{StaticResource Btn}" Content="▶  Play" Padding="12,6"
                        IsEnabled="False" Click="OnPlayPauseClick"/>
                <Button x:Name="StopBtn" Style="{StaticResource Btn}" Content="■" Padding="10,6"
                        Margin="8,0,0,0" IsEnabled="False" Click="OnStopClick" ToolTip="Stop and rewind"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="6">
            <Grid>
                <!-- Interactive segment view: follows playback, click to jump. -->
                <ListBox x:Name="SegmentsList" Visibility="Collapsed"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         SelectionChanged="OnSegmentSelected">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="46"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Time}" FontSize="11"
                                           Foreground="{StaticResource BlueBrush}" VerticalAlignment="Top"
                                           Margin="0,1,0,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding SpeakerDisplay}" FontSize="12"
                                           FontWeight="SemiBold" Foreground="{Binding SpeakerBrush}"
                                           Visibility="{Binding SpeakerVisibility}" VerticalAlignment="Top"
                                           Margin="0,0,8,0" Cursor="Hand"
                                           ToolTip="Click to rename this speaker"
                                           PreviewMouseLeftButtonDown="OnSpeakerClick"/>
                                <TextBlock Grid.Column="2" Text="{Binding Text}" FontSize="13"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <!-- Fallback for no-segment results and errors. -->
                <TextBox x:Name="TranscriptBox" IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" BorderThickness="0"
                         Background="Transparent" FontSize="13" Padding="10"
                         Text="…"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <TextBlock x:Name="SavedText" Style="{StaticResource Dim}" FontSize="11"
                       VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CopyBtn" Style="{StaticResource Btn}" Content="Copy" Padding="16,7"
                        IsEnabled="False" Click="OnCopyClick"/>
                <Button Style="{StaticResource Btn}" Content="Close" Padding="16,7"
                        Margin="8,0,0,0" Click="OnCloseClick"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
