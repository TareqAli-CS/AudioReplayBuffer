<Window x:Class="AudioReplayBuffer.UI.TranscriptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transcript"
        Icon="/app.ico"
        Width="640" Height="560" MinWidth="480" MinHeight="380"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18,14,18,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock x:Name="FileNameText" Style="{StaticResource H2}" Text="Replay.mp3"/>
                <TextBlock x:Name="StatusText" Style="{StaticResource Dim}" FontSize="12"
                           Margin="0,3,0,0" Text="Transcribing — uploading to Groq…"/>
            </StackPanel>
            <CheckBox x:Name="TimestampsCheck" Content="Timestamps" FontSize="12"
                      HorizontalAlignment="Right" VerticalAlignment="Center" IsEnabled="False"
                      Checked="OnTimestampsToggled" Unchecked="OnTimestampsToggled"/>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="4">
            <TextBox x:Name="TranscriptBox" IsReadOnly="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" BorderThickness="0"
                     Background="Transparent" FontSize="13" Padding="10"
                     Text="…"/>
        </Border>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <TextBlock x:Name="SavedText" Style="{StaticResource Dim}" FontSize="11"
                       VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CopyBtn" Style="{StaticResource Btn}" Content="Copy" Padding="16,7"
                        IsEnabled="False" Click="OnCopyClick"/>
                <Button Style="{StaticResource Btn}" Content="Close" Padding="16,7"
                        Margin="8,0,0,0" Click="OnCloseClick"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
