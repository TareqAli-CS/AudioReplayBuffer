<Window x:Class="AudioReplayBuffer.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:AudioReplayBuffer.UI"
        Title="Audio Replay Buffer"
        Icon="/app.ico"
        Width="820" Height="860" MinWidth="660" MinHeight="680"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        Closing="OnWindowClosing">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="58"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ============ NAV RAIL ============ -->
        <Border Grid.Column="0" Background="#121217">
            <DockPanel Margin="9,14,9,14">
                <StackPanel DockPanel.Dock="Top">
                    <Button x:Name="SoundboardTabBtn" Style="{StaticResource Btn}" Content="🎛"
                            Width="40" Height="40" Padding="0" FontSize="17"
                            Click="OnSoundboardTabClick" ToolTip="Soundboard"/>
                    <Button x:Name="ReplaysTabBtn" Style="{StaticResource Btn}" Content="🎙"
                            Width="40" Height="40" Padding="0" FontSize="17" Margin="0,10,0,0"
                            Click="OnReplaysTabClick" ToolTip="Replay recorder"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom">
                    <Ellipse x:Name="RailDot" Width="10" Height="10" HorizontalAlignment="Center"
                             Fill="{StaticResource AccentBrush}" ToolTip="Recording"/>
                    <Button Style="{StaticResource Btn}" Content="⚙" Width="40" Height="40" Padding="0"
                            FontSize="16" Margin="0,12,0,0" Click="OnSettingsClick" ToolTip="Settings"/>
                </StackPanel>
                <Grid/>
            </DockPanel>
        </Border>

        <!-- ============ CONTENT ============ -->
        <Grid Grid.Column="1" Margin="16,14,20,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ======== REPLAY VIEW ======== -->
            <Grid x:Name="ReplayView" Grid.Row="0" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Status card -->
                <Border Grid.Row="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="StatusText" Text="Recording" FontSize="16" FontWeight="SemiBold" Margin="9,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="ClearBtn" Style="{StaticResource Btn}" Content="Clear" Padding="10,6"
                                        FontSize="12" Click="OnClearClick"
                                        ToolTip="Discard the audio captured so far (saved files are not affected)"/>
                                <Button x:Name="PauseBtn" Style="{StaticResource Btn}" Content="■ Stop" Padding="10,6"
                                        FontSize="12" Margin="8,0,0,0" Click="OnPauseClick"
                                        ToolTip="Stop buffering — no audio is captured or stored until you press Start. The app always launches recording."/>
                            </StackPanel>
                        </Grid>
                        <TextBlock x:Name="StatusSub" Style="{StaticResource Dim}" Margin="0,6,0,14"
                                   Text="Desktop audio — keeping the last 5 minutes"/>

                        <TextBlock Text="LEVEL" FontSize="10" Foreground="{StaticResource DimBrush}" Margin="0,0,0,5"/>
                        <ProgressBar x:Name="LevelBar" Maximum="100" Foreground="{StaticResource GreenBrush}"/>

                        <Grid Margin="0,12,0,5">
                            <TextBlock Text="BUFFERED" FontSize="10" Foreground="{StaticResource DimBrush}"/>
                            <TextBlock x:Name="BufferedText" Style="{StaticResource Dim}" FontSize="11"
                                       HorizontalAlignment="Right" Text="0:00 / 5:00"/>
                        </Grid>
                        <ProgressBar x:Name="BufferBar" Foreground="{StaticResource BlueBrush}"/>

                        <TextBlock Text="WAVEFORM" FontSize="10" Foreground="{StaticResource DimBrush}" Margin="0,12,0,5"/>
                        <ui:WaveformView x:Name="WaveView" Height="52"/>
                    </StackPanel>
                </Border>

                <!-- Save card -->
                <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,14,0,0">
                    <StackPanel>
                        <Button x:Name="SaveBtn" Style="{StaticResource BtnAccent}" Height="48"
                                FontSize="15" FontWeight="SemiBold" Click="OnSaveClick">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="10" Height="10" Fill="White" VerticalAlignment="Center"/>
                                <TextBlock Text="Save replay" Foreground="White" Margin="9,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="ClipBtn" Style="{StaticResource Btn}" Height="34" Margin="0,8,0,0"
                                Content="Save last 30 s  (Ctrl+Alt+D)" Click="OnClipClick"/>
                        <TextBlock x:Name="HotkeyHint" Style="{StaticResource Dim}" FontSize="12"
                                   HorizontalAlignment="Center" Margin="0,9,0,0"
                                   Text="or press Ctrl+Alt+S anywhere"/>
                    </StackPanel>
                </Border>

                <!-- Recent replays -->
                <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,14,0,0">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top">
                            <TextBlock Text="Recent replays" Style="{StaticResource H2}" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="MicPlayBtn" Style="{StaticResource Btn}" Content="Play to mic"
                                        Padding="10,5" FontSize="12" Click="OnPlayToMicClick"
                                        ToolTip="Play the selected replay into your virtual mic so people in your call hear it (set the device in Settings)"/>
                                <Button Style="{StaticResource Btn}" Content="Edit" Padding="10,5"
                                        FontSize="12" Margin="8,0,0,0" Click="OnEditClick"
                                        ToolTip="Open the selected replay in the editor (trim, cut, fades, volume)"/>
                                <Button Style="{StaticResource Btn}" Content="Rename" Padding="10,5"
                                        FontSize="12" Margin="8,0,0,0" Click="OnRenameClick"
                                        ToolTip="Set a label, rename the file, or bind it to a soundboard hotkey (Ctrl+Alt+1..9)"/>
                                <Button Style="{StaticResource Btn}" Content="Open folder" Padding="10,5"
                                        FontSize="12" Margin="8,0,0,0" Click="OnOpenFolderClick"/>
                                <Button Style="{StaticResource Btn}" Content="Delete" Padding="10,5"
                                        FontSize="12" Margin="8,0,0,0" Click="OnDeleteReplayClick"
                                        ToolTip="Move the selected replay to the Recycle Bin"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <ListBox x:Name="RecentList" MouseDoubleClick="OnRecentDoubleClick"
                                     PreviewMouseRightButtonDown="OnRecentPreviewRightClick"
                                     ContextMenuOpening="OnRecentMenuOpening">
                                <ListBox.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Play to mic" Click="OnPlayToMicClick"/>
                                        <MenuItem Header="Play on this PC" Click="OnPlayLocalClick"/>
                                        <Separator/>
                                        <MenuItem Header="Edit" Click="OnEditClick"/>
                                        <MenuItem Header="Rename / hotkey…" Click="OnRenameClick"/>
                                        <MenuItem Header="Send to soundboard" Click="OnSendToSoundboardClick"/>
                                        <MenuItem Header="Show in Explorer" Click="OnShowInExplorerClick"/>
                                        <Separator/>
                                        <MenuItem Header="Delete" Click="OnDeleteReplayClick"/>
                                    </ContextMenu>
                                </ListBox.ContextMenu>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="13"/>
                                            <TextBlock Text="{Binding Details}" FontSize="11"
                                                       Foreground="{StaticResource DimBrush}" Margin="0,1,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock x:Name="NoRecentText" Style="{StaticResource Dim}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Text="No replays yet — something worth keeping? Hit save."/>
                        </Grid>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- ======== SOUNDBOARD VIEW ======== -->
            <Grid x:Name="SoundboardView" Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="2,0,2,10">
                    <TextBlock Text="Soundboard" Style="{StaticResource H2}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <CheckBox x:Name="MirrorCheck" Content="Hear it too" FontSize="11"
                                  VerticalAlignment="Center" Margin="0,0,10,0"
                                  ToolTip="Also play through your speakers. Causes echo if your real mic can hear your speakers, or if Voicemod's 'Hear myself' is already on — untick to fix."/>
                        <Slider x:Name="VoiceVolumeSlider" Width="130" Minimum="0" Maximum="200"
                                TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center"
                                ValueChanged="OnVoiceVolumeChanged"/>
                        <TextBlock x:Name="VoiceVolumeText" Style="{StaticResource Dim}" FontSize="11"
                                   Width="36" Margin="6,0,0,0" VerticalAlignment="Center"
                                   TextAlignment="Right" Text="100%"/>
                    </StackPanel>
                </Grid>

                <Border x:Name="SoundboardCard" Grid.Row="1" Style="{StaticResource Card}"
                        AllowDrop="True" Drop="OnSoundboardDrop" DragOver="OnSoundboardDragOver">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="PadSearchBox" Grid.Column="0" TextChanged="OnPadSearchChanged"
                                     ToolTip="Type to filter sounds"/>
                            <Button Grid.Column="1" Style="{StaticResource Btn}" Content="＋ Add sounds"
                                    Padding="10,5" FontSize="12" Margin="8,0,0,0" Click="OnAddSoundsClick"
                                    ToolTip="Import MP3/WAV files into the soundboard (you can also drag &amp; drop them here)"/>
                        </Grid>
                        <WrapPanel x:Name="CategoryChips" DockPanel.Dock="Top" Margin="0,0,0,6"/>
                        <Grid>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="PadsGrid">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource PadBtn}" Click="OnPadClick" Tag="{Binding}"
                                                    PreviewMouseLeftButtonDown="OnPadMouseDown"
                                                    PreviewMouseMove="OnPadMouseMove">
                                                <Button.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="Play on this PC" Click="OnPadPlayLocalClick"/>
                                                        <MenuItem Header="Edit sound…" Click="OnPadEditClick"/>
                                                        <MenuItem Header="Rename / hotkey / volume…" Click="OnPadPropertiesClick"/>
                                                        <MenuItem Header="Move / copy to category…" Click="OnPadMoveClick"/>
                                                        <MenuItem Header="Show in Explorer" Click="OnPadExplorerClick"/>
                                                        <Separator/>
                                                        <MenuItem Header="Delete" Click="OnPadDeleteClick"/>
                                                    </ContextMenu>
                                                </Button.ContextMenu>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontSize="12" TextWrapping="Wrap"
                                                               MaxHeight="34" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Sub}" FontSize="10"
                                                               Foreground="{StaticResource DimBrush}" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <TextBlock x:Name="NoPadsText" Style="{StaticResource Dim}" TextWrapping="Wrap"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"
                                       Text="No sounds yet.&#10;Drag &amp; drop MP3/WAV files here, press “＋ Add sounds”,&#10;or right-click a replay → Send to soundboard."/>
                        </Grid>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Shared status line + footer -->
            <TextBlock x:Name="SaveStatus" Grid.Row="1" FontSize="12" HorizontalAlignment="Center"
                       Margin="0,8,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
            <TextBlock Grid.Row="2" Style="{StaticResource Dim}" FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,6"
                       Text="Closing this window keeps recording in the background — right-click the tray icon to exit."/>
        </Grid>
    </Grid>
</Window>
