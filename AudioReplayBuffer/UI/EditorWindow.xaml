<Window x:Class="AudioReplayBuffer.UI.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:AudioReplayBuffer.UI"
        Title="Edit replay"
        Icon="/app.ico"
        Width="900" Height="600" MinWidth="780" MinHeight="500"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <StackPanel>
                <TextBlock x:Name="FileNameText" Style="{StaticResource H2}" Text="Replay.mp3"/>
                <TextBlock x:Name="DurationText" Style="{StaticResource Dim}" FontSize="12"
                           Margin="0,3,0,0" Text="0:00"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="PlayBtn" Style="{StaticResource Btn}" Content="▶  Play" Click="OnPlayClick"/>
                <Button x:Name="PlaySelBtn" Style="{StaticResource Btn}" Content="▶  Play selection"
                        Margin="8,0,0,0" Click="OnPlaySelectionClick"/>
                <Button x:Name="StopBtn" Style="{StaticResource Btn}" Content="■  Stop"
                        Margin="8,0,0,0" Click="OnStopClick"/>
            </StackPanel>
        </Grid>

        <!-- Waveform -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,14,0,0" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ui:EditorWaveformView x:Name="Wave" Grid.Row="0"/>
                <ui:RangeSlider x:Name="RangeSel" Grid.Row="1" Height="26" Margin="2,8,2,0"
                                ToolTip="Drag the handles to set the start and end of the range"/>
                <Grid Grid.Row="2" Margin="2,8,2,0">
                    <TextBlock x:Name="SelInfoText" Style="{StaticResource Dim}" FontSize="12"
                               VerticalAlignment="Center"
                               Text="Drag the handles below the waveform (or drag on the waveform) to choose a range"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource Btn}" Content="Select all" Padding="10,5"
                                FontSize="12" Click="OnSelectAllClick"/>
                        <Button Style="{StaticResource Btn}" Content="Clear selection" Padding="10,5"
                                FontSize="12" Margin="8,0,0,0" Click="OnClearSelectionClick"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Tools -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,14,0,0" Padding="14,12">
            <StackPanel>
                <WrapPanel>
                    <Button x:Name="TrimBtn" Style="{StaticResource Btn}" Content="Trim to selection"
                            Margin="0,0,8,0" Click="OnTrimClick"/>
                    <Button x:Name="DeleteBtn" Style="{StaticResource Btn}" Content="Delete selection"
                            Margin="0,0,8,0" Click="OnDeleteClick"/>
                    <Button x:Name="FadeInBtn" Style="{StaticResource Btn}" Content="Fade in"
                            Margin="0,0,8,0" Click="OnFadeInClick"/>
                    <Button x:Name="FadeOutBtn" Style="{StaticResource Btn}" Content="Fade out"
                            Margin="0,0,8,0" Click="OnFadeOutClick"/>
                    <Button x:Name="NormalizeBtn" Style="{StaticResource Btn}" Content="Normalize"
                            Margin="0,0,8,0" Click="OnNormalizeClick"/>
                    <Button Style="{StaticResource Btn}" Content="⇄ Reverse"
                            Margin="0,0,8,0" Click="OnReverseClick"/>
                    <Button Style="{StaticResource Btn}" Content="🐿 Chipmunk"
                            Margin="0,0,8,0" Click="OnChipmunkClick"
                            ToolTip="Faster and higher-pitched"/>
                    <Button Style="{StaticResource Btn}" Content="🐻 Deep voice"
                            Margin="0,0,8,0" Click="OnDeepVoiceClick"
                            ToolTip="Slower and lower-pitched"/>
                    <Button x:Name="UndoBtn" Style="{StaticResource Btn}" Content="Undo"
                            Margin="0,0,8,0" Click="OnUndoClick" IsEnabled="False"/>
                </WrapPanel>
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <TextBlock Text="Volume" Style="{StaticResource Dim}" FontSize="12" VerticalAlignment="Center"/>
                    <Slider x:Name="GainSlider" Width="150" Minimum="10" Maximum="300" Value="100"
                            TickFrequency="5" IsSnapToTickEnabled="True" Margin="10,0,0,0"
                            VerticalAlignment="Center" ValueChanged="OnGainSliderChanged"/>
                    <TextBlock x:Name="GainText" Style="{StaticResource Dim}" FontSize="12" Width="42"
                               Margin="8,0,0,0" VerticalAlignment="Center" Text="100%"/>
                    <Button x:Name="ApplyGainBtn" Style="{StaticResource Btn}" Content="Apply volume"
                            Padding="10,5" FontSize="12" Click="OnApplyGainClick"/>
                    <TextBlock Style="{StaticResource Dim}" FontSize="11" Margin="12,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap"
                               Text="Tools apply to the selected range (or the whole file). Saving also exports only the selected range."/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Save -->
        <Grid Grid.Row="3" Margin="0,14,0,0">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="SaveCopyBtn" Style="{StaticResource BtnAccent}" Content="Save as copy"
                        Padding="16,8" Click="OnSaveCopyClick"/>
                <Button x:Name="OverwriteBtn" Style="{StaticResource Btn}" Content="Overwrite original"
                        Margin="8,0,0,0" Click="OnOverwriteClick"/>
            </StackPanel>
            <TextBlock x:Name="EditStatus" FontSize="12" HorizontalAlignment="Right"
                       VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="380"/>
        </Grid>
    </Grid>
</Window>
