<Window x:Class="AudioReplayBuffer.UI.LauncherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sound launcher"
        Width="480" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="True"
        WindowStartupLocation="CenterScreen"
        Deactivated="OnDeactivated" PreviewKeyDown="OnKeyDown">
    <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardBorderBrush}"
            BorderThickness="1" CornerRadius="12" Padding="14" Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.5"/>
        </Border.Effect>
        <StackPanel>
            <TextBox x:Name="QueryBox" FontSize="15" TextChanged="OnQueryChanged"/>
            <ListBox x:Name="ResultsList" MaxHeight="300" Margin="0,8,0,0"
                     MouseUp="OnResultClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <TextBlock Text="{Binding Title}" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Sub}" FontSize="11" Foreground="{StaticResource DimBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <TextBlock Style="{StaticResource Dim}" FontSize="10" Margin="2,8,0,0"
                       Text="Enter — play into the call   ·   Esc — close"/>
        </StackPanel>
    </Border>
</Window>
