<Window x:Class="AudioReplayBuffer.UI.CategoryPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Move to category"
        Icon="/app.ico"
        Width="360" SizeToContent="Height" ResizeMode="NoResize"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <StackPanel Margin="18,14,18,16">
        <TextBlock Text="Choose a category" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>
        <Border Background="{StaticResource InputBrush}" CornerRadius="8" Padding="4">
            <ListBox x:Name="CategoryList" MaxHeight="260" MouseDoubleClick="OnMoveClick"/>
        </Border>
        <TextBlock Style="{StaticResource Dim}" FontSize="11" Margin="2,8,0,0" TextWrapping="Wrap"
                   Text="Move relocates the sound; Copy leaves the original where it is (label and volume are copied, the hotkey stays on the original)."/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Style="{StaticResource Btn}" Content="Cancel" Padding="14,7" Click="OnCancelClick"/>
            <Button Style="{StaticResource Btn}" Content="Copy" Padding="16,7" Margin="8,0,0,0" Click="OnCopyClick"/>
            <Button Style="{StaticResource BtnAccent}" Content="Move" Padding="20,7" Margin="8,0,0,0" Click="OnMoveClick"/>
        </StackPanel>
    </StackPanel>
</Window>
